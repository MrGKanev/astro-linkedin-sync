{
  "name": "astro-linkedin-sync",
  "version": "0.1.0",
  "description": "Sync your LinkedIn profile (data export ZIP + PDF) into Astro content collections. One-way: LinkedIn → Astro.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "astro-linkedin-sync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas.js",
      "types": "./dist/schemas.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "cli": "node --experimental-strip-types src/cli.ts"
  },
  "keywords": [
    "astro",
    "linkedin",
    "sync",
    "content-collections",
    "portfolio",
    "cv",
    "resume"
  ],
  "license": "MIT",
  "dependencies": {
    "yauzl": "^3.1.3",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8",
    "gray-matter": "^4.0.3",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/yauzl": "^2.10.3",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.6.2"
  }
}
