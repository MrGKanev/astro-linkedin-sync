{
  "name": "astro-linkedin-sync",
  "version": "0.2.2",
  "description": "Sync your LinkedIn profile (data export ZIP + PDF) into Astro content collections. Ships an Astro integration and drop-in components.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Gabriel Kanev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrGKanev/astro-linkedin-sync"
  },
  "bugs": {
    "url": "https://github.com/MrGKanev/astro-linkedin-sync/issues"
  },
  "homepage": "https://github.com/MrGKanev/astro-linkedin-sync#readme",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "bin": {
    "astro-linkedin-sync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    },
    "./components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "cli": "node --experimental-strip-types src/cli.ts",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build && tsc --noEmit && pnpm test"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "linkedin",
    "sync",
    "content-collections",
    "portfolio",
    "cv",
    "resume"
  ],
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "dependencies": {
    "yauzl": "^3.4.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3",
    "gray-matter": "^4.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/yauzl": "^3.4.0",
    "@types/pdf-parse": "^1.1.5",
    "astro": "^7.0.2",
    "typescript": "^6.0.3"
  }
}
